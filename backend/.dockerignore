# Version control
.git
.gitignore

# Python virtual environments
.venv/
venv/
env/

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# IDE & editor files
.vscode/
.idea/

# Logs & temp
*.log
logs/

# Secrets & environment (CRITICAL)
.env
.env.local
.env.*.local
*.key
*.pem
*.secret
